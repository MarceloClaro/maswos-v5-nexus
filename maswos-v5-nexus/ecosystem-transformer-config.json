                "layer": "Aggregation",
                "transformer_mapping": "Multi-Head Attention",
                "description": "Agrega resultados de múltiplos MCPS",
                "strategies": ["weighted_merge", "priority_based", "consensus"]
            },
            {
                "id": "mcp_status_monitor",
                "name": "MCP Status Monitor",
                "layer": "Aggregation",
                "description": "Monitora status de todos os MCPS integrados",
                "health_checks": ["availability", "latency", "capacity"]
            },
            {
                "id": "scraper_collector",
                "name": "Scraper Collection Agent",
                "layer": "Collection",
                "transformer_mapping": "Multi-Source Collector",
                "description": "Coordena coleta de dados de múltiplas fontes via scrapers",
                "capabilities": ["multi_source_collection", "parallel_scraping", "cache_management"],
                "sources": ["ARXIV", "PUBMED", "SEMANTICSCHOLAR", "DOAJ", "CORE", "AMINER", "DADOSGOV", "CAPES", "IBGE", "WORLD_BANK", "INTERNATIONAL", "INTERNET_ARCHIVE"]
            },
            {
                "id": "academic_collector",
                "name": "Academic Collection Agent",
                "layer": "Collection",
                "transformer_mapping": "Academic Domain Collector",
                "description": "Coleta dados acadêmicos de fontes especializadas",
                "domains": {
                    "cs": ["ARXIV", "SEMANTICSCHOLAR", "OPENREVIEW"],
                    "biomedical": ["PUBMED", "SEMANTICSCHOLAR", "DOAJ"],
                    "general": ["ARXIV", "PUBMED", "SEMANTICSCHOLAR", "DOAJ"]
                }
            },
            {
                "id": "brazilian_data_collector",
                "name": "Brazilian Data Collector",
                "layer": "Collection",
                "transformer_mapping": "National Data Collector",
                "description": "Coleta dados brasileiros de fontes governamentais",
                "data_types": {
                    "demographic": ["IBGE"],
                    "government": ["DADOSGOV", "IBGE"],
                    "academic": ["CAPES"],
                    "historical": ["INTERNET_ARCHIVE"]
                }
            },
            {
                "id": "international_data_collector",
                "name": "International Data Collector",
                "layer": "Collection",
                "transformer_mapping": "Global Data Collector",
                "description": "Coleta dados de organizações internacionais",
                "sources": ["WORLD_BANK", "WORLD_BANK_DOCS", "INTERNATIONAL"]
            },
            {
                "id": "pageindex_encoder",
                "name": "PageIndex Encoder",
                "layer": "Encoder",
                "transformer_mapping": "Tree Index Builder",
                "description": "Indexa documentos usando tree-based RAG",
                "capabilities": ["document_indexing", "tree_construction", "context_preservation"]
            },
            {
                "id": "pageindex_decoder",
                "name": "PageIndex Decoder",
                "layer": "Decoder",
                "transformer_mapping": "Reasoning Query",
                "description": "Executa queries reasoning-based em documentos indexados",
                "capabilities": ["tree_search", "reasoning_path", "context_retrieval"]
            },
            {
                "id": "pageindex_rag_orchestrator",
                "name": "PageIndex RAG Orchestrator",
                "layer": "Synthesis",
                "transformer_mapping": "Multi-Document Aggregator",
                "description": "Orquestra RAG multi-documento com tree reasoning",
                "capabilities": ["multi_document_rag", "cross_document_reasoning", "result_aggregation"]
            },
            {
                "id": "autonomous_agent",
                "name": "MASWOS Autonomous Agent",
                "layer": "Autonomous",
                "transformer_mapping": "Agent Loop (Claude+Manus)",
                "description": "Agente autônomo baseado em Claude Agent Loop + Manus Planner",
                "inspired_by": ["Claude Agent SDK", "Manus AI"],
                "capabilities": [
                    "goal_decomposition",
                    "parallel_execution",
                    "tool_calling",
                    "memory_persistence",
                    "self_correction",
                    "code_execution",
                    "mcp_integration"
                ],
                "components": {
                    "planner": "TaskPlanner - decomposição de objetivos",
                    "memory": "AgentMemory - camadas de memória",
                    "tools": "ToolRegistry - ferramentas disponíveis",
                    "loop": "MASWOSAutonomousAgent - agent loop"
                },
                "sub_agents": [
                    "ResearchSubAgent",
                    "CodeSubAgent"
                ]
            }
        ],
        "validator": [
            {
                "id": "cross_mcp_validator",
                "name": "Cross-MCP Validator",
                "layer": "Validation",
                "transformer_mapping": "Layer Normalization",
                "description": "Valida consistência entre resultados de MCPS",
                "checks": ["semantic_consistency", " factual_alignment", "quality_threshold"]
            }
        ],
        "rag": [
            {
                "id": "R01",
                "name": "VanillaRetriever",
                "layer": "Retrieval",
                "transformer_mapping": "Similarity Search",
                "description": "Executor de busca básica RAG",
                "rag_type": "vanilla"
            },
            {
                "id": "R02",
                "name": "VanillaAugmenter",
                "layer": "Augmentation",
                "transformer_mapping": "Context Concatenation",
                "description": "Construtor de prompts",
                "rag_type": "vanilla"
            },
            {
                "id": "R03",
                "name": "VanillaGenerator",
                "layer": "Output",
                "transformer_mapping": "Output Projection",
                "description": "Gerador de respostas",
                "rag_type": "vanilla"
            },
            {
                "id": "R04",
                "name": "MemoryManager",
                "layer": "Retrieval",
                "transformer_mapping": "Memory Context",
                "description": "Gerenciador de memória Redis",
                "rag_type": "memory"
            },
            {
                "id": "R05",
                "name": "SessionContextBuilder",
                "layer": "Augmentation",
                "transformer_mapping": "Session Embedding",
                "description": "Construtor de contexto de sessão",
                "rag_type": "memory"
            },
            {
                "id": "R06",
                "name": "DatasetRouter",
                "layer": "Retrieval",
                "transformer_mapping": "Dynamic Routing",
                "description": "Roteador de datasets",
                "rag_type": "agentic"
            },
            {
                "id": "R07",
                "name": "QueryClassifier",
                "layer": "Encoder",
                "transformer_mapping": "Classification",
                "description": "Classificador de queries",
                "rag_type": "agentic"
            },
            {
                "id": "R08",
                "name": "AgentCoordinator",
                "layer": "Control",
                "transformer_mapping": "Agent Orchestration",
                "description": "Coordenador de agentes",
                "rag_type": "agentic"
            },
            {
                "id": "R09",
                "name": "GraphEntityExtractor",
                "layer": "Encoder",
                "transformer_mapping": "Entity Recognition",
                "description": "Extrator de entidades",
                "rag_type": "graph"
            },
            {
                "id": "R10",
                "name": "GraphQueryExecutor",
                "layer": "Retrieval",
                "transformer_mapping": "Graph Traversal",
                "description": "Executor de queries em grafo",
                "rag_type": "graph"
            },
            {
                "id": "R11",
                "name": "HybridFusionEngine",
                "layer": "Retrieval",
                "transformer_mapping": "Multi-Modal Fusion",
                "description": "Motor de fusão híbrida",
