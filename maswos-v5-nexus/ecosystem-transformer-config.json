{
  "name": "ecosystem-transformer",
  "version": "5.0.0-NEXUS",
  "description": "MASWOS V5 NEXUS - Cross-MCP Orchestration com arquitetura Transformer",
  "architecture": {
    "transformer_mapping": true,
    "mcp_registry": {
      "maswos-juridico": {
        "agents": 60,
        "domains": ["legal"],
        "layers": ["Encoder", "Collection", "Validation", "Analysis", "Synthesis", "Output"]
      },
      "maswos-mcp": {
        "agents": 15,
        "domains": ["skill-generation"],
        "layers": ["Encoder", "Validation", "AgentFactory", "Decoder", "Control"]
      },
      "academic": {
        "agents": 55,
        "domains": ["academic", "research", "data_collection", "document_rag"],
        "layers": ["Encoder", "Collection", "Validation", "Analysis", "Synthesis", "Output"],
        "scrapers": [
          {"id": "A04", "name": "arXiv", "type": "academic", "papers": "2M+"},
          {"id": "A05", "name": "PubMed/NCBI", "type": "biomedical", "papers": "35M+"},
          {"id": "A06", "name": "Semantic Scholar", "type": "academic", "papers": "200M+"},
          {"id": "A07", "name": "DOAJ", "type": "journals", "journals": "21K+"},
          {"id": "A08", "name": "CORE", "type": "academic", "papers": "300M+"},
          {"id": "A09", "name": "OpenAlex", "type": "academic", "papers": "250M+"},
          {"id": "A10", "name": "Europe PMC", "type": "biomedical", "papers": "37M+"},
          {"id": "A11", "name": "AMiner", "type": "academic_china", "papers": "300M+"},
          {"id": "A12", "name": "OpenReview", "type": "ai_conferences", "venues": "50+"},
          {"id": "A13", "name": "CAPES", "type": "brazilian_academic", "accesses": "460M+"},
          {"id": "A14", "name": "Internet Archive", "type": "historical", "items": "40M+"}
        ],
        "government_apis": [
          {"id": "N09", "name": "IBGE", "type": "demographic", "apis": "25+"},
          {"id": "N10", "name": "INEP", "type": "education"},
          {"id": "N11", "name": "CNJ", "type": "justice"},
          {"id": "N12", "name": "DATASUS", "type": "health"},
          {"id": "N13", "name": "IPEA", "type": "economic"},
          {"id": "N14", "name": "World Bank", "type": "international", "indicators": "14K+"},
          {"id": "N15", "name": "dados.gov.br", "type": "government_open_data", "datasets": "15K+"}
        ]
      },
      "pageindex-mcp": {
        "agents": 10,
        "domains": ["document_rag", "reasoning_search", "tree_indexing"],
        "layers": ["Encoder", "Decoder"],
        "capabilities": [
          "index_documents",
          "query_documents",
          "rag_search",
          "tree_reasoning",
          "multi_document_aggregation"
        ],
        "features": {
          "vectorless_rag": true,
          "tree_indexing": true,
          "reasoning_search": true,
          "no_chunking": true,
          "context_preservation": true
        },
        "api": {
          "url": "https://api.pageindex.ai/mcp",
          "auth": "api_key",
          "registration": "https://dash.pageindex.ai/api-keys"
        }
      },
      "maswos-rag": {
        "agents": 21,
        "domains": ["rag_retrieval", "semantic_search", "knowledge_graph", "multi_source"],
        "layers": ["Encoder", "Retrieval", "Validation", "Augmentation", "Generation", "Output"],
        "strategies": [
          {"type": "vanilla", "class": "VanillaRAG", "path": "rag.classic.vanilla_rag"},
          {"type": "memory", "class": "MemoryRAG", "path": "rag.memory.memory_rag"},
          {"type": "agentic", "class": "AgenticRAG", "path": "rag.agentic.agentic_rag"},
          {"type": "graph", "class": "GraphRAG", "path": "rag.graph.graph_rag"},
          {"type": "hybrid", "class": "HybridRAG", "path": "rag.hybrid.hybrid_rag"},
          {"type": "crag", "class": "CRAG", "path": "rag.corrective.crag"},
          {"type": "adaptive", "class": "AdaptiveRAG", "path": "rag.adaptive.adaptive_rag"},
          {"type": "fusion", "class": "RAGFusion", "path": "rag.fusion.rag_fusion"},
          {"type": "hyde", "class": "HyDE", "path": "rag.hyde.hyde"}
        ],
        "orchestrator": {
          "class": "RAGOrchestrator",
          "path": "rag.orchestrator.rag_orchestrator"
        }
      }
    },
    "layers": ["Input", "Routing", "ParallelExecution", "Aggregation", "Output"],
    "quality_gates": ["G0", "GR", "GE", "GF"]
  },
  "agents": {
    "orchestrator": {
      "id": "orchestrator_unified",
      "name": "Orchestrator Unificado",
      "layer": "Input",
      "transformer_mapping": "Input Embedding",
      "description": "Detecta intent e roteia para MCP correto",
      "capabilities": ["intent_detection", "mcp_routing", "cross_mcp_coordination"]
    },
    "router": [
      {
        "id": "intent_router",
        "name": "Intent Router",
        "layer": "Routing",
        "transformer_mapping": "Self-Attention",
        "description": "Roteia intents para MCPS específicos",
        "decision_matrix": {
          "juridico": ["juridico_petition", "jurisprudence_search", "legal_advice"],
          "skill_generation": ["create_skill", "generate_agents", "assemble_workflow"],
          "academic": ["research_paper", "collect_data", "validate_methodology"],
          "rag": ["semantic_search", "knowledge_graph", "multi_source_search", "validate_sources", "adaptive_query"]
        }
      },
      {
        "id": "cross_mcp_query",
        "name": "Cross-MCP Query",
        "layer": "Routing",
        "description": "Executa query simultânea em múltiplos MCPS",
        "parallel_execution": true
      }
    ],
    "aggregator": [
      {
        "id": "result_aggregator",
        "name": "Result Aggregator",
        "layer": "Aggregation",
        "transformer_mapping": "Multi-Head Attention",
        "description": "Agrega resultados de múltiplos MCPS",
        "strategies": ["weighted_merge", "priority_based", "consensus"]
      },
      {
        "id": "mcp_status_monitor",
        "name": "MCP Status Monitor",
        "layer": "Aggregation",
        "description": "Monitora status de todos os MCPS integrados",
        "health_checks": ["availability", "latency", "capacity"]
      },
      {
        "id": "scraper_collector",
        "name": "Scraper Collection Agent",
        "layer": "Collection",
        "transformer_mapping": "Multi-Source Collector",
        "description": "Coordena coleta de dados de múltiplas fontes via scrapers",
        "capabilities": ["multi_source_collection", "parallel_scraping", "cache_management"],
        "sources": ["ARXIV", "PUBMED", "SEMANTICSCHOLAR", "DOAJ", "CORE", "AMINER", "DADOSGOV", "CAPES", "IBGE", "WORLD_BANK", "INTERNATIONAL", "INTERNET_ARCHIVE"]
      },
      {
        "id": "academic_collector",
        "name": "Academic Collection Agent",
        "layer": "Collection",
        "transformer_mapping": "Academic Domain Collector",
        "description": "Coleta dados acadêmicos de fontes especializadas",
        "domains": {
          "cs": ["ARXIV", "SEMANTICSCHOLAR", "OPENREVIEW"],
          "biomedical": ["PUBMED", "SEMANTICSCHOLAR", "DOAJ"],
          "general": ["ARXIV", "PUBMED", "SEMANTICSCHOLAR", "DOAJ"]
        }
      },
      {
        "id": "brazilian_data_collector",
        "name": "Brazilian Data Collector",
        "layer": "Collection",
        "transformer_mapping": "National Data Collector",
        "description": "Coleta dados brasileiros de fontes governamentais",
        "data_types": {
          "demographic": ["IBGE"],
          "government": ["DADOSGOV", "IBGE"],
          "academic": ["CAPES"],
          "historical": ["INTERNET_ARCHIVE"]
        }
      },
      {
        "id": "international_data_collector",
        "name": "International Data Collector",
        "layer": "Collection",
        "transformer_mapping": "Global Data Collector",
        "description": "Coleta dados de organizações internacionais",
        "sources": ["WORLD_BANK", "WORLD_BANK_DOCS", "INTERNATIONAL"]
      },
      {
        "id": "pageindex_encoder",
        "name": "PageIndex Encoder",
        "layer": "Encoder",
        "transformer_mapping": "Tree Index Builder",
        "description": "Indexa documentos usando tree-based RAG",
        "capabilities": ["document_indexing", "tree_construction", "context_preservation"]
      },
      {
        "id": "pageindex_decoder",
        "name": "PageIndex Decoder",
        "layer": "Decoder",
        "transformer_mapping": "Reasoning Query",
        "description": "Executa queries reasoning-based em documentos indexados",
        "capabilities": ["tree_search", "reasoning_path", "context_retrieval"]
      },
      {
        "id": "pageindex_rag_orchestrator",
        "name": "PageIndex RAG Orchestrator",
        "layer": "Synthesis",
        "transformer_mapping": "Multi-Document Aggregator",
        "description": "Orquestra RAG multi-documento com tree reasoning",
        "capabilities": ["multi_document_rag", "cross_document_reasoning", "result_aggregation"]
      }
    ],
    "validator": [
      {
        "id": "cross_mcp_validator",
        "name": "Cross-MCP Validator",
        "layer": "Validation",
        "transformer_mapping": "Layer Normalization",
        "description": "Valida consistência entre resultados de MCPS",
        "checks": ["semantic_consistency", " factual_alignment", "quality_threshold"]
      }
    ]
  },
    "agents": {
        "orchestrator": {
            "id": "orchestrator_unified",
            "name": "Orchestrator Unificado",
            "layer": "Input",
            "transformer_mapping": "Input Embedding",
            "description": "Detecta intent e roteia para MCP correto",
            "capabilities": ["intent_detection", "mcp_routing", "cross_mcp_coordination"]
        },
        "router": [
            {
                "id": "intent_router",
                "name": "Intent Router",
                "layer": "Routing",
                "transformer_mapping": "Self-Attention",
                "description": "Roteia intents para MCPS específicos",
                "decision_matrix": {
                    "juridico": ["juridico_petition", "jurisprudence_search", "legal_advice"],
                    "skill_generation": ["create_skill", "generate_agents", "assemble_workflow"],
                    "academic": ["research_paper", "collect_data", "validate_methodology"]
                }
            },
            {
                "id": "cross_mcp_query",
                "name": "Cross-MCP Query",
                "layer": "Routing",
                "description": "Executa query simultânea em múltiplos MCPS",
                "parallel_execution": true
            }
        ],
        "aggregator": [
            {
                "id": "result_aggregator",
