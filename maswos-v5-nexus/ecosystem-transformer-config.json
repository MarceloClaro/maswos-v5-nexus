    "pipelines": {
        "juridico_petition": {
      "description": "Pipeline para geração de petições jurídicas",
      "mcp_sequence": ["maswos-juridico"],
      "required_agents": ["N01", "N03", "N13", "N14", "N21", "N25"],
      "quality_threshold": 0.95,
      "output_format": "peticao_OAB"
    },
    "skill_generation": {
      "description": "Pipeline para geração de skills",
      "mcp_sequence": ["maswos-mcp"],
      "required_agents": ["N01_intent_parser", "domain_analyzer", "scope_mapper", "agent_factory_core", "skill_assembler"],
      "tier_routing": true,
      "output_format": "SKILL.md"
    },
    "academic_research": {
      "description": "Pipeline para pesquisa acadêmica com coleta via scrapers",
      "mcp_sequence": ["academic"],
      "required_agents": ["research_planner", "scraper_collector", "academic_collector", "paper_collector", "dataset_loader", "methodology_generator"],
      "quality_threshold": 0.90,
      "output_format": "academic_paper",
      "scraper_integration": {
        "enabled": true,
        "sources": ["ARXIV", "PUBMED", "SEMANTICSCHOLAR", "DOAJ", "CORE", "OPENALEX"],
        "fallback_strategy": "multi_source"
      }
    },
    "brazilian_data_collection": {
      "description": "Pipeline para coleta de dados brasileiros",
      "mcp_sequence": ["academic"],
      "required_agents": ["brazilian_data_collector", "scraper_collector"],
      "quality_threshold": 0.85,
      "output_format": "dataset",
      "scraper_integration": {
        "enabled": true,
        "sources": ["IBGE", "CAPES", "DADOSGOV", "DATASUS", "IPEA"],
        "fallback_strategy": "parallel"
      }
    },
    "international_data_collection": {
      "description": "Pipeline para coleta de dados internacionais",
      "mcp_sequence": ["academic"],
      "required_agents": ["international_data_collector", "scraper_collector"],
      "quality_threshold": 0.85,
      "output_format": "dataset",
      "scraper_integration": {
        "enabled": true,
        "sources": ["WORLD_BANK", "WORLD_BANK_DOCS", "INTERNATIONAL"],
        "fallback_strategy": "sequential"
      }
    },
    "pageindex_rag_pipeline": {
      "description": "Pipeline RAG vectorless com PageIndex",
      "mcp_sequence": ["pageindex-mcp"],
      "required_agents": ["pageindex_encoder", "pageindex_decoder", "pageindex_rag_orchestrator"],
      "quality_threshold": 0.92,
      "output_format": "reasoned_answer",
      "features": {
        "tree_indexing": true,
        "reasoning_search": true,
        "no_chunking": true,
        "multi_document": true
      }
    },
    "hybrid_rag_pipeline": {
      "description": "Pipeline híbrido: scrapers + PageIndex RAG",
      "mcp_sequence": ["academic", "pageindex-mcp"],
      "required_agents": ["scraper_collector", "academic_collector", "pageindex_encoder", "pageindex_decoder", "pageindex_rag_orchestrator"],
      "quality_threshold": 0.95,
      "output_format": "research_document",
      "workflow": {
        "step1": "Collect data from scrapers (arXiv, PubMed, etc.)",
        "step2": "Index documents with PageIndex (tree-based)",
        "step3": "Query with reasoning using PageIndex decoder",
        "step4": "Aggregate results with cross-document reasoning"
      }
    },
    "cross_mcp_workflow": {
      "description": "Workflow que combina múltiplos MCPS",
      "mcp_sequence": ["maswos-juridico", "maswos-mcp"],
      "use_cases": [
        "legal_research_with_skill_generation",
        "academic_research_with_legal_validation",
        "comprehensive_research_with_generation"
      ]
    },
    "maswos_rag_pipeline": {
      "description": "Pipeline RAG avançado com 9 estratégias de recuperação",
      "mcp_sequence": ["maswos-rag"],
